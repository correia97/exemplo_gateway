  "components": {
    "schemas": {
      "AlbumResponse": {
        "required": [
          "id",
          "title",
          "releaseDate",
          "coverUrl",
          "artistId",
          "artistName",
          "createdAt",
          "updatedAt"
        ],
        "type": "object",
        "properties": {
          "id": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "title": {
            "type": "string"
          },
          "releaseDate": {
            "type": [
              "null",
              "string"
            ],
            "format": "date"
          },
          "coverUrl": {
            "type": [
              "null",
              "string"
            ]
          },
          "artistId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "artistName": {
            "type": [
              "null",
              "string"
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ArtistResponse": {
        "required": [
          "id",
          "name",
          "biography",
          "genres",
          "createdAt",
          "updatedAt"
        ],
        "type": "object",
        "properties": {
          "id": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "name": {
            "type": "string"
          },
          "biography": {
            "type": [
              "null",
              "string"
            ]
          },
          "genres": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GenreSummary"
            }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateAlbumRequest": {
        "required": [
          "title",
          "releaseDate",
          "coverUrl",
          "artistId"
        ],
        "type": "object",
        "properties": {
          "title": {
