    {
      "name": "Routes",
      "item": [
        {
          "name": "DragonBall GET",
          "request": {
            "method": "PUT",
            "url": "{{admin-api}}/routes/dragonball-get",
            "header": [
              {
                "key": "X-API-KEY",
                "value": "{{admin-key}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"uri\": \"/api/dragonball/*\",\n    \"methods\": [\"GET\"],\n    \"strip_path\": true,\n    \"upstream_id\": \"dragonball\",\n    \"plugins\": {\n        \"cors\": {\n            \"allow_origins\": \"{{cors-origins}}\",\n            \"allow_methods\": \"GET,POST,PUT,DELETE,OPTIONS\",\n            \"allow_headers\": \"*\",\n            \"expose_headers\": \"X-Correlation-Id\",\n            \"allow_credential\": true,\n            \"max_age\": 86400\n        }\n    }\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function() {",
