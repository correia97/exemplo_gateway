{
  "info": {
    "name": "OpenCode - APISIX Configuration",
    "description": "Collection para configurar rotas e upstreams no Apache APISIX",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "admin-api",
      "value": "http://localhost:9180/apisix/admin",
      "type": "string"
    },
    {
      "key": "admin-key",
      "value": "edd1c9f034335f136f87ad84b625c8f1",
      "type": "string"
    },
    {
      "key": "upstream-dragonball",
      "value": "http://dragonball-api:8080",
      "type": "string"
    },
    {
      "key": "upstream-music",
      "value": "http://music-api:8080",
      "type": "string"
    },
    {
      "key": "cors-origins",
      "value": "http://localhost:5173,http://localhost:3000,http://localhost:4200,http://localhost,http://localhost:5003",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Global Rules",
      "item": [
        {
          "name": "Create Correlation ID Rule",
          "request": {
            "method": "PUT",
            "url": "{{admin-api}}/global_rules/correlation-id",
            "header": [
              {
                "key": "X-API-KEY",
                "value": "{{admin-key}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"plugins\": {\n        \"request-id\": {\n            \"header_name\": \"X-Correlation-Id\",\n            \"include_in_response\": true,\n            \"algorithm\": \"uuid\"\n        }\n    }\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function() {",
                  "    pm.expect(pm.response.status).to.be.oneOf([200, 201]);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Upstreams",
      "item": [
        {
          "name": "Create DragonBall Upstream",
          "request": {
            "method": "PUT",
            "url": "{{admin-api}}/upstreams/dragonball",
            "header": [
              {
                "key": "X-API-KEY",
                "value": "{{admin-key}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"type\": \"roundrobin\",\n    \"nodes\": {\n        \"{{upstream-dragonball}}\": 1\n    }\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function() {",
                  "    pm.expect(pm.response.status).to.be.oneOf([200, 201]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Music Upstream",
          "request": {
            "method": "PUT",
            "url": "{{admin-api}}/upstreams/music",
            "header": [
              {
                "key": "X-API-KEY",
                "value": "{{admin-key}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"type\": \"roundrobin\",\n    \"nodes\": {\n        \"{{upstream-music}}\": 1\n    }\n}"
